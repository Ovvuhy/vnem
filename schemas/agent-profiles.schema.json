{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VNEM Agent Profiles",
  "type": "object",
  "required": ["schema_version", "generated_at", "profiles"],
  "properties": {
    "schema_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "display_name", "applies_to", "known_mcp_support_status", "known_skill_support_status", "function_tool_calling_notes", "recommended_vnem_usage_style", "strengths", "weaknesses", "avoid_instructions", "token_efficiency_tips", "confidence", "source_urls"],
        "properties": {
          "id": { "type": "string" },
          "display_name": { "type": "string" },
          "applies_to": { "type": "array", "items": { "type": "string" } },
          "known_mcp_support_status": { "type": "string" },
          "known_skill_support_status": { "type": "string" },
          "function_tool_calling_notes": { "type": "string" },
          "recommended_vnem_usage_style": { "type": "array", "items": { "type": "string" } },
          "strengths": { "type": "array", "items": { "type": "string" } },
          "weaknesses": { "type": "array", "items": { "type": "string" } },
          "avoid_instructions": { "type": "array", "items": { "type": "string" } },
          "token_efficiency_tips": { "type": "array", "items": { "type": "string" } },
          "confidence": { "enum": ["high", "medium", "low", "unknown"] },
          "source_urls": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
