# Required for opening pull requests.
GITHUB_TOKEN=
HERMES_GITHUB_REPO=owner/repo

# Runtime behavior.
HERMES_BASE_BRANCH=main
HERMES_CREATE_PR=1
HERMES_GIT_SYNC=1
HERMES_ALLOW_DIRTY=0
HERMES_MAX_CANDIDATES=20
HERMES_PROPOSE_REGISTRY=0
HERMES_REGISTRY_PROPOSAL_LIMIT=3
HERMES_FETCH_TIMEOUT_MS=15000
HERMES_STATE_PATH=.hermes/state.json

# Optional: custom GitHub search queries. Use semicolons, newlines, or a JSON array.
# HERMES_GITHUB_QUERIES=topic:mcp;topic:agent-framework;topic:llm-agent

# Optional: official sources to hash-watch during daily runs.
# HERMES_WATCH_URLS=https://platform.openai.com/docs/changelog;https://docs.anthropic.com/en/release-notes

# Optional: disable official MCP registry route.
# HERMES_INCLUDE_MCP_REGISTRY=0
