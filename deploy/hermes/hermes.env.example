# Required for opening pull requests.
GITHUB_TOKEN=
HERMES_GITHUB_REPO=owner/repo

# Runtime behavior.
HERMES_BASE_BRANCH=main
HERMES_CREATE_PR=1
HERMES_GIT_SYNC=1
HERMES_ALLOW_DIRTY=0
HERMES_MAX_CANDIDATES=20
HERMES_MIN_PER_ROUTE=2
HERMES_PROPOSE_REGISTRY=0
HERMES_REGISTRY_PROPOSAL_LIMIT=3
HERMES_FETCH_TIMEOUT_MS=30000
HERMES_STATE_PATH=.hermes/state.json

# Optional localhost-only dashboard API. Expose it with Cloudflare Tunnel,
# not a public inbound VPS port.
VNEM_REPO_DIR=/opt/vnem
HERMES_DASHBOARD_API_HOST=127.0.0.1
HERMES_DASHBOARD_API_PORT=8788
HERMES_DASHBOARD_API_TOKEN=

# Optional: custom GitHub search queries. Use semicolons, newlines, or a JSON array.
# HERMES_GITHUB_QUERIES=topic:mcp;topic:agent-framework;topic:llm-agent

# Optional: watched GitHub repositories whose latest releases should be checked.
# HERMES_RELEASE_REPOS=modelcontextprotocol/modelcontextprotocol;github/github-mcp-server;NousResearch/hermes-agent

# Optional: npm package search. Disable with HERMES_INCLUDE_NPM=0.
# HERMES_NPM_QUERIES=mcp server;agent memory;coding agent;agent eval

# Optional: forum/social lead generation. Hacker News is enabled by default.
# These are always watchlist leads and require primary-source verification.
# HERMES_HN_QUERIES=model context protocol;coding agent;agent memory;OpenAI Codex
# HERMES_INCLUDE_REDDIT=0
# HERMES_REDDIT_SUBREDDITS=LocalLLaMA;ClaudeAI;ChatGPTCoding;MachineLearning
# HERMES_REDDIT_QUERIES=mcp;coding agent;agent framework;agent memory

# Optional: official sources to hash-watch during daily runs.
# HERMES_WATCH_URLS=https://platform.openai.com/docs/changelog;https://docs.anthropic.com/en/release-notes

# Optional: route toggles.
# HERMES_INCLUDE_MCP_REGISTRY=0
# HERMES_INCLUDE_GITHUB_RELEASES=0
# HERMES_INCLUDE_NPM=0
# HERMES_INCLUDE_HACKER_NEWS=0

# Optional: repository trust review and hard blocklists.
# HERMES_REPO_REVIEW=1
# HERMES_BLOCKED_REPOS=owner/suspicious-repo;https://github.com/owner/another-repo
# HERMES_BLOCKED_DOMAINS=example-download-host.com;example-shortener.test
