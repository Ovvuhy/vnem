# Nous Hermes brain layer for vnem.
# Copy to /etc/hermes/hermes-brain.env.

HERMES_BRAIN_ENABLED=1
HERMES_BRAIN_PROVIDER=openrouter

# Leave empty to use the default model in /home/hermes/.hermes/config.yaml.
# Example:
# HERMES_BRAIN_MODEL=openrouter/owl-alpha
HERMES_BRAIN_MODEL=openrouter/owl-alpha

# Keep the persistent VPS clone on its startup branch after a brain pass.
HERMES_BRAIN_RESTORE_BRANCH=1

# Optional override for smoke tests or narrower runs.
# HERMES_BRAIN_PROMPT=
# HERMES_BRAIN_SKILLS=codebase-inspection,github-repo-management,github-pr-workflow

# Required when HERMES_BRAIN_PROVIDER=openrouter.
# You can put this here or in /home/hermes/.hermes/.env.
OPENROUTER_API_KEY=

# Optional GitHub token for API operations such as opening PRs.
# Branch pushes still require the VPS deploy key to be added to the repo.
GITHUB_TOKEN=

# The repo Hermes should maintain.
VNEM_REPO_DIR=/opt/vnem
